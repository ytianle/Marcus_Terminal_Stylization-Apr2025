{
  "$schema": "https://ohmyposh.dev/schema.json",
  "version": 2,
  "final_space": false,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "\uE0B6",
          "trailing_diamond": "\uE0B4",
          "foreground": "#FFFFFF",
          "background": "#0B1020",
          "template": "\uF179"
        },
        {
          "type": "session",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#FFFFFF",
          "background": "#111827",
          "template": " \uF007 {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#FFD580",
          "template": " \uF07B {{ .Path }} ",
          "properties": {
            "style": "folder",
            "truncate_to_repo": false,
            "max_depth": 0,
            "home_icon": "\uF015",
            "folder_icon": "\uF07B",
            "folder_separator_icon": " \u276F "
          }
        },
        {
          "type": "git",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#A5D8FF",
          "template": " {{ .HEAD }}{{ if .Working.Changed }} \u2717{{ end }}{{ if .Staging.Changed }} \u25CF{{ end }} "
        },
        {
          "type": "aws",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#FFD8A8",
          "template": " \uF0C2 AWS ",
          "display_mode": "context"
        },
        {
          "type": "azure",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#A5D8FF",
          "template": " \uF0C2 AZ ",
          "display_mode": "context"
        },
        {
          "type": "gcp",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#D1F7E0",
          "template": " \uF0C2 GCP ",
          "display_mode": "context"
        },
        {
          "type": "docker",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#BEE3F8",
          "template": " \uF308 ",
          "display_mode": "context"
        },
        {
          "type": "node",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#CFF8D8",
          "template": " \uE718 {{ .Full }} ",
          "display_mode": "context"
        },
        {
          "type": "python",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#EDE9FE",
          "template": " \uE73C {{ .Venv }} ",
          "display_mode": "context"
        },
        {
          "type": "status",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#FFE4E6",
          "template": " {{ if eq .Code 0 }}\u2714 ok{{ else }}\u2718 rc {{ .Code }}{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#E9D5FF",
          "template": " \u23F1 {{ .FormattedMs }} ",
          "options": {
            "threshold": 350,
            "style": "austin"
          }
        },
        {
          "type": "jobs",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#0B1020",
            "background": "#F8FAFC",
          "template": " \uF0AE jobs {{ .Count }} ",
          "display_mode": "context"
        },
        
        {
          "type": "time",
          "style": "diamond",
          "trailing_diamond": "\uE0B4",
          "foreground": "#FFFFFF",
          "background": "#0B1020",
          "template": " \uF017 {{ .CurrentDate | date \"15:04\" }} "
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#A78BFA",
          "template": ">>> "
        }
      ]
    }
  ]
}
