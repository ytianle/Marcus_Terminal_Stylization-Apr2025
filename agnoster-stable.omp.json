{
  "$schema": "https://ohmyposh.dev/schema.json",
  "version": 2,
  "final_space": false,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "foreground": "#FFFFFF",
          "background": "#0B1020",
          "template": "\uf179"
        },
        {
          "type": "session",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#FFFFFF",
          "background": "#111827",
          "template": " \uf007 {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#FFD580",
          "template": " \uf115 {{ .Path }} ",
          "properties": {
            "style": "full",
            "truncate_to_repo": false
          }
        },
        {
          "type": "git",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#A5D8FF",
          "template": " \uf09b {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if gt .StashCount 0 }} \uf692 {{ .StashCount }}{{ end }}{{ if .Working.Changed }} \u2717 {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} \u25cf {{ .Staging.String }}{{ end }} ",
          "properties": {
            "branch_icon": "\uf126 "
          }
        },
        {
          "type": "aws",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#FFD8A8",
          "template": " \uf270 AWS {{ .Profile }} {{ .Region }} ",
          "display_mode": "context",
          "properties": {
            "display_default": false
          }
        },
        {
          "type": "azure",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#A5D8FF",
          "template": " \ufd03 AZ ",
          "display_mode": "context"
        },
        {
          "type": "gcp",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#D1F7E0",
          "template": " \uf1a0 GCP ",
          "display_mode": "context"
        },
        {
          "type": "docker",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#BEE3F8",
          "template": " \uf395 ",
          "display_mode": "context"
        },
        {
          "type": "node",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#CFF8D8",
          "template": " \uf419 {{ .Full }} ",
          "display_mode": "context"
        },
        {
          "type": "python",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#EDE9FE",
          "template": " \uf3e2 {{ .Venv }} ",
          "display_mode": "context"
        },
        {
          "type": "status",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#FFE4E6",
          "template": " {{ if eq .Code 0 }}\u2714 ok{{ else }}\u2718 rc {{ .Code }}{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#E9D5FF",
          "template": " \u23f1 {{ .FormattedMs }} ",
          "options": {
            "threshold": 350,
            "style": "austin"
          }
        },
        {
          "type": "jobs",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#0B1020",
          "background": "#F8FAFC",
          "template": " \uf0ae jobs {{ .Count }} ",
          "display_mode": "context"
        },
        {
          "type": "time",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "#FFFFFF",
          "background": "#0B1020",
          "template": " \uf017 {{ .CurrentDate | date \"15:04\" }} "
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#A78BFA",
          "template": ">>> "
        }
      ]
    }
  ]
}
